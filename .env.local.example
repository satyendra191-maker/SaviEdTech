# =============================================================================
# SaviEduTech Local Environment Configuration
# =============================================================================
# Copy this file to .env.local for local development
# This file contains all required and optional configuration

# =============================================================================
# Supabase Configuration (Required)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_PROJECT_ID=your_project_ref
SUPABASE_DB_PASSWORD=your_supabase_database_password
# Optional direct connection string for non-interactive migration pushes
SUPABASE_DB_URL=postgresql://postgres:your_supabase_database_password@db.your-project.supabase.co:5432/postgres

# =============================================================================
# Application Configuration (Required)
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SaviEduTech

# =============================================================================
# Payment Gateway - Razorpay (Required for payments)
# =============================================================================
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# =============================================================================
# Security & Admin Configuration (Required)
# =============================================================================
# Cron Job Security - Use a random string min 32 characters
CRON_SECRET=your_secure_random_string_min_32_chars
# Admin API Access
ADMIN_API_KEY=your_admin_api_key
# Self-Healing System API Key
SELF_HEALING_API_KEY=your_self_healing_api_key

# =============================================================================
# Email Configuration - Resend (Required for notifications)
# =============================================================================
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@saviedutech.com

# =============================================================================
# AI Content Generation (Optional - for AI features)
# =============================================================================
# OpenAI API
OPENAI_API_KEY=sk-your_openai_key
# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key

# =============================================================================
# Cloudflare Configuration (Optional - for video streaming)
# =============================================================================
NEXT_PUBLIC_CLOUDFLARE_STREAM_TOKEN=your_cloudflare_stream_token

# =============================================================================
# Analytics (Optional)
# =============================================================================
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id

# =============================================================================
# Feature Flags
# =============================================================================
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
