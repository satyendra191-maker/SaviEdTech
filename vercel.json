{
    "version": 2,
    "buildCommand": "npm run build",
    "devCommand": "npm run dev",
    "installCommand": "npm install",
    "framework": "nextjs",
    "outputDirectory": ".next",
    "regions": [
        "bom1"
    ],
    "crons": [
        {
            "path": "/api/cron/ai-content",
            "schedule": "0 2 * * *"
        },
        {
            "path": "/api/cron/exam-engine",
            "schedule": "0 3 * * *"
        },
        {
            "path": "/api/cron/student-analytics",
            "schedule": "0 4 * * *"
        },
        {
            "path": "/api/cron/engagement",
            "schedule": "0 5 * * *"
        },
        {
            "path": "/api/cron/marketing-automation",
            "schedule": "0 6 * * *"
        },
        {
            "path": "/api/cron/daily-challenge",
            "schedule": "0 6 * * *"
        },
        {
            "path": "/api/cron/financial-automation",
            "schedule": "0 7 * * *"
        },
        {
            "path": "/api/cron/database-maintenance",
            "schedule": "0 8 * * *"
        },
        {
            "path": "/api/cron/security-monitoring",
            "schedule": "0 9 * * *"
        },
        {
            "path": "/api/cron/performance-optimization",
            "schedule": "0 10 * * *"
        },
        {
            "path": "/api/cron/automated-testing",
            "schedule": "0 11 * * *"
        },
        {
            "path": "/api/cron/live-class-automation",
            "schedule": "0 12 * * *"
        },
        {
            "path": "/api/cron/lead-management",
            "schedule": "0 13 * * *"
        },
        {
            "path": "/api/cron/supabase-health",
            "schedule": "0 14 * * *"
        },
        {
            "path": "/api/cron/auth-check",
            "schedule": "0 15 * * *"
        },
        {
            "path": "/api/cron/health-monitor",
            "schedule": "0 4 * * *"
        },
        {
            "path": "/api/cron/rank-prediction",
            "schedule": "30 4 * * *"
        },
        {
            "path": "/api/cron/gamification",
            "schedule": "0 0 * * *"
        },
        {
            "path": "/api/cron/lecture-publisher",
            "schedule": "10 2 * * *"
        },
        {
            "path": "/api/cron/platform-auditor",
            "schedule": "0 16 * * *"
        },
        {
            "path": "/api/cron/system-maintenance",
            "schedule": "30 8 * * *"
        },
        {
            "path": "/api/cron/email-notifications",
            "schedule": "0 7 * * 1"
        },
        {
            "path": "/api/cron/seo-automation",
            "schedule": "0 6 * * 1"
        },
        {
            "path": "/api/cron/database-backup",
            "schedule": "0 1 * * *"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(self), microphone=(self), display-capture=(self), geolocation=(), interest-cohort=()"
                }
            ]
        },
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-store, max-age=0"
                }
            ]
        },
        {
            "source": "/_next/static/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}
