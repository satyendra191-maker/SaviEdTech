# =============================================================================
# SaviEduTech Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values
# Do not commit .env.local to version control

# =============================================================================
# Supabase Configuration (Required)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_PROJECT_ID=your_project_ref
SUPABASE_DB_PASSWORD=your_supabase_database_password
# Optional direct connection string for non-interactive migration pushes
SUPABASE_DB_URL=postgresql://postgres:your_supabase_database_password@db.your-project.supabase.co:5432/postgres

# =============================================================================
# Application Configuration (Required)
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SaviEduTech

# =============================================================================
# Payment Gateway - Razorpay (Required for payments)
# =============================================================================
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# =============================================================================
# Security & Admin Configuration (Required)
# =============================================================================
# Cron Job Security - Use a random string min 32 characters
CRON_SECRET=your_secure_random_string_min_32_chars
# Admin API Access
ADMIN_API_KEY=your_admin_api_key
# Self-Healing System API Key
SELF_HEALING_API_KEY=your_self_healing_api_key

# =============================================================================
# Email Configuration - Resend (Required for notifications)
# =============================================================================
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@saviedutech.com

# =============================================================================
# AI Content Generation (Optional - for AI features)
# =============================================================================
# OpenAI API
OPENAI_API_KEY=sk-your_openai_key
# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key

# =============================================================================
# Cloudflare Configuration (Optional - for video streaming)
# =============================================================================
NEXT_PUBLIC_CLOUDFLARE_STREAM_TOKEN=your_cloudflare_stream_token

# =============================================================================
# Analytics (Optional)
# =============================================================================
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id

# =============================================================================
# Redis Cache (Optional - for improved performance)
# =============================================================================
# Format: redis://username:password@host:port
# Example: redis://default:your_password@your-redis.upstash.io:6379
REDIS_URL=your_redis_url

# =============================================================================
# Feature Flags
# =============================================================================
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# =============================================================================
# YouTube API (For Virtual Lab Videos)
# =============================================================================
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CHANNEL_ID=your_channel_id

# =============================================================================
# Wolfram Alpha API (For Math/Physics Computations)
# =============================================================================
WOLFRAM_ALPHA_APP_ID=your_wolfram_app_id

# =============================================================================
# PubChem API (For Chemistry Molecules - Free, no key required)
# =============================================================================
# No API key needed - uses public API

# =============================================================================
# AR/VR Support (WebXR - No API key needed)
# =============================================================================
# WebXR is built into modern browsers

# =============================================================================
# Google OAuth (For Authentication)
# =============================================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
