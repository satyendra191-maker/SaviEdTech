# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SaviEduTech

# Cloudflare Configuration (for video streaming)
NEXT_PUBLIC_CLOUDFLARE_STREAM_TOKEN=your_cloudflare_stream_token

# Email Configuration (Resend)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@saviedutech.com

# Analytics
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# =============================================================================
# Payment Gateway Configuration
# =============================================================================

# Razorpay (India) - https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Stripe (International) - https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal - https://developer.paypal.com
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret

# =============================================================================
# Security & Admin Configuration
# =============================================================================

# Cron Job Security (required for automated tasks)
CRON_SECRET=your_secure_random_string_min_32_chars

# Admin API Access
ADMIN_API_KEY=your_admin_api_key

# Self-Healing System
SELF_HEALING_API_KEY=your_self_healing_api_key

# =============================================================================
# AI Content Generation (Optional)
# =============================================================================

# OpenAI API for AI content generation
OPENAI_API_KEY=sk-your_openai_key

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key
